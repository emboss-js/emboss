---
interface Props {
  size?: number;
}

const { size = 30 } = Astro.props;
---

<svg width={size} height={size} viewBox="0 0 48 48" fill="none" aria-label="Emboss logo">
  <defs>
    <radialGradient id="dip" cx="0.85" cy="0.75" r="1.2" fx="0.95" fy="0.95">
      <stop offset="0%" stop-color="#38bdf8" stop-opacity="0.9"/>
      <stop offset="25%" stop-color="#3b82f6" stop-opacity="0.6"/>
      <stop offset="50%" stop-color="#3b82f6" stop-opacity="0.3"/>
      <stop offset="80%" stop-color="#3b82f6" stop-opacity="0"/>
    </radialGradient>
  </defs>
  <rect width="48" height="48" rx="12" fill="#1e1c19"/>
  <rect width="48" height="48" rx="12" fill="url(#dip)"/>
  <text x="24" y="32.5" text-anchor="middle" font-family="'DM Serif Display', Georgia, serif" font-size="30" font-weight="400" fill="white">E</text>
</svg>
