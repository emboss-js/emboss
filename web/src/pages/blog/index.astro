---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base title="Blog" description="Updates, thoughts, and announcements from the Emboss team.">
  <section class="section" style="padding-top: 140px;">
    <p class="section-label">Blog</p>
    <h1 class="section-title">From the workshop</h1>
    <p class="section-desc">Updates, thoughts, and the occasional tangent about making open source beautiful.</p>

    <div class="post-list">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="post-card">
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .post-card {
    display: block;
    padding: 32px;
    border-radius: 20px;
    background: var(--emboss-surface-raised);
    border: 1px solid var(--emboss-border);
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--emboss-lift-md);
  }

  .post-card time {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--emboss-ash);
    letter-spacing: 0.04em;
  }

  .post-card h2 {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 400;
    color: var(--emboss-coal);
    margin-top: 8px;
    line-height: 1.3;
  }
  :global([data-theme="dark"]) .post-card h2 { color: var(--emboss-white); }

  .post-card p {
    font-size: 15px;
    color: var(--emboss-slate);
    margin-top: 8px;
    line-height: 1.6;
  }
  :global([data-theme="dark"]) .post-card p { color: var(--emboss-ash); }
</style>
