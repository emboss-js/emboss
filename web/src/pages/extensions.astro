---
import Base from '../layouts/Base.astro';
---

<Base title="Extensions" description="Browse Emboss extensions — tooltips, dependency arrows, sidebar, milestones, and more.">
  <section class="placeholder">
    <p class="section-label">Extensions</p>
    <h1 class="section-title">Coming soon</h1>
    <p class="section-desc">The extension marketplace is on its way. Core ships with today marker, tooltips, and dependency arrows — all free.</p>
    <a href="/" class="btn-secondary">&larr; Back to home</a>
  </section>
</Base>

<style>
  .placeholder {
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 40px 80px;
  }
  .placeholder .section-desc {
    margin-bottom: 32px;
  }
</style>
