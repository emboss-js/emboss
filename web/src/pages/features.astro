    position: absolute; inset: 0; border-radius: 13px;
    background: var(--emboss-cloud);
  }
  :global([data-theme="dark"] .g-track) { background: var(--emboss-graphite); }
  :global(.g-fill) {
    position: absolute; top: 0; left: 0; bottom: 0;
    border-radius: 13px 0 0 13px;
  }
  :global(.g-fill.full) { border-radius: 13px; }
  :global(.g-fill::before) {
    content: ''; position: absolute; top: 2px; left: 4px; right: 4px;
    height: 40%; border-radius: 8px;
    background: linear-gradient(180deg, rgba(255,255,255,0.5) 0%, rgba(255,255,255,0.12) 60%, transparent 100%);
  }
  :global(.g-fill::after) {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 35%;
    background: linear-gradient(0deg, rgba(0,0,0,0.1) 0%, transparent 100%);
    border-radius: 0 0 0 13px;
  }
  :global(.g-fill.full::after) { border-radius: 0 0 13px 13px; }
  :global(.g-label) {
    position: absolute; top: 50%; transform: translateY(-50%);
