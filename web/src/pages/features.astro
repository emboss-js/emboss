  :global(.g-marker) {
    position: absolute; top: 50%; transform: translate(-50%,-50%);
    width: 12px; height: 12px; border-radius: 50%; background: white;
    box-shadow: 0 0 0 2px white, 0 2px 4px rgba(0,0,0,0.15); z-index: 3;
