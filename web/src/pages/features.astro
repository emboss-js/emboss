  :global(.g-diamond.done) { opacity: 0.45; }

  /* ═══════════════════════════════════════════
     DEMO: VIEWS
     ═══════════════════════════════════════════ */
  :global(.demo-views-wrap) {
    border-radius: 16px; overflow: hidden;
    border: 1px solid var(--emboss-border);
