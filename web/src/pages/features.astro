---
import Base from '../layouts/Base.astro';
---

<Base title="Features" description="Every extension, every tier. See what ships free with Emboss core and what the Organize bundle adds.">

<!-- PAGE HERO -->
<section class="page-hero">
  <p class="section-label">Features</p>
  <h1>Everything ships as<br>an <em>extension</em></h1>
  <p>Free extensions come with the package. Paid bundles add the structure, flare, and analysis you'd otherwise build yourself.</p>
</section>

<!-- ═══════════════════════════════════════════
     FREE EXTENSIONS
     ═══════════════════════════════════════════ -->
<section class="section">
  <p class="section-label">Included with core</p>
  <h2 class="section-title">Free extensions</h2>
  <p class="section-desc">These ship with <code style="font-size:15px;background:var(--emboss-surface-inset);padding:2px 8px;border-radius:4px">@emboss-js/core</code> and are MIT licensed. Import what you need, leave what you don't.</p>

  <!-- ──── GLASS BARS ──── -->
  <div class="feature-row">
    <div class="feature-text">
      <span class="feature-badge free">Core</span>
      <h3>Glass-finished bars</h3>
      <p>The signature visual. Every bar is two layers — a track at full width and a fill at progress width — with a glass highlight, dimensional shadow, and progress marker dot.</p>
      <div class="feature-detail">
        Progress marker at fill edge (hidden at 0% and 100%). Smart labels: inside when bar is wide enough, outside when narrow. Drag handles appear on hover. Done bars dim to 45%. Upcoming bars show the full track at 50% opacity.
      </div>
    </div>
    <div class="feature-visual" style="border:none;box-shadow:none;background:transparent">
      <div class="demo-theme-wrap">
        <div class="demo-theme-tabs">
          <button class="demo-theme-tab active" onclick="setBarMode('grayscale',this)">Grayscale</button>
          <button class="demo-theme-tab" onclick="setBarMode('vivid',this)">&#10022; Vivid</button>
        </div>
        <div class="demo-chart" id="glassDemo" style="min-height:180px">
          <!-- Done bar -->
          <div class="g-row">
            <div class="g-bar bar-done" style="left:12px;width:200px;">
              <div class="g-track"></div>
              <div class="g-fill fill-done full gb-done" style="width:100%"></div>
              <div class="g-handle g-handle-l"></div><div class="g-handle g-handle-r"></div>
              <span class="g-label inside">Research & Discovery</span>
            </div>
          </div>
          <!-- Active bar with progress -->
          <div class="g-row">
            <div class="g-bar" style="left:60px;width:260px;">
              <div class="g-track"></div>
              <div class="g-fill fill-active gb-active" style="width:180px"></div>
              <div class="g-marker" style="left:180px"><div class="g-marker-inner gb-marker" style="background:#574f45"></div></div>
              <div class="g-handle g-handle-l"></div><div class="g-handle g-handle-r"></div>
              <span class="g-label inside">Core Architecture &middot; 69%</span>
            </div>
          </div>
          <!-- Narrow active bar (label outside) -->
          <div class="g-row">
            <div class="g-bar" style="left:200px;width:60px;">
              <div class="g-track"></div>
              <div class="g-fill fill-active gb-active" style="width:24px"></div>
              <div class="g-marker" style="left:24px"><div class="g-marker-inner gb-marker" style="background:#574f45"></div></div>
              <div class="g-handle g-handle-l"></div><div class="g-handle g-handle-r"></div>
              <span class="g-label outside" style="left:66px;">API &middot; 40%</span>
            </div>
          </div>
          <!-- Upcoming bar -->
          <div class="g-row">
            <div class="g-bar bar-upcoming" style="left:140px;width:200px;">
              <div class="g-track"></div>
              <div class="g-fill fill-upcoming gb-upcoming" style="width:100%;opacity:0.5;border-radius:13px"></div>
              <div class="g-handle g-handle-l"></div><div class="g-handle g-handle-r"></div>
              <span class="g-label inside" style="opacity:0.75;">Organize Bundle</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ──── TODAY MARKER ──── -->
  <div class="feature-row reverse">
    <div class="feature-text">
      <span class="feature-badge free">Free</span>
      <h3>Today Marker</h3>
      <p>A pulsing vertical line that always shows where you are in the timeline. Red line, solid dot, animated ring, and a subtle column glow behind it.</p>
      <div class="feature-detail">
        1.5px line at 50% opacity. 8px dot. 16px ring pulsing to 1.6&times; scale over 2 seconds. ~40px glow column at 2% opacity. "TODAY" label in monospace above.
      </div>
    </div>
    <div class="feature-visual">
      <div class="demo-chart" style="min-height:180px">
        <!-- Grid lines -->
        <div class="g-grid" style="left:80px"></div>
        <div class="g-grid" style="left:160px"></div>
        <div class="g-grid" style="left:240px"></div>
        <div class="g-grid" style="left:320px"></div>
        <!-- Today marker -->
        <div style="position:absolute;left:195px;top:0;bottom:0;z-index:10;">
          <div class="today-glow" style="left:0"></div>
          <div class="today-line" style="left:0">
            <span class="today-lbl">TODAY</span>
            <div class="today-dot"></div>
            <div class="today-ring"></div>
          </div>
        </div>
        <!-- Bars behind the marker -->
        <div class="g-row">
          <div class="g-bar bar-done" style="left:20px;width:160px;">
            <div class="g-track"></div><div class="g-fill fill-done full" style="width:100%"></div>
            <span class="g-label inside">Design System</span>
          </div>
        </div>
        <div class="g-row">
          <div class="g-bar" style="left:80px;width:220px;">
            <div class="g-track"></div><div class="g-fill fill-active" style="width:120px"></div>
            <div class="g-marker" style="left:120px"><div class="g-marker-inner" style="background:#574f45"></div></div>
            <span class="g-label inside">Core Architecture &middot; 55%</span>
          </div>
        </div>
        <div class="g-row">
          <div class="g-bar" style="left:160px;width:180px;">
            <div class="g-track"></div><div class="g-fill fill-active" style="width:40px"></div>
            <div class="g-marker" style="left:40px"><div class="g-marker-inner" style="background:#574f45"></div></div>
            <span class="g-label inside">Extension API &middot; 22%</span>
          </div>
        </div>
        <div class="g-row">
          <div class="g-bar bar-upcoming" style="left:260px;width:120px;">
            <div class="g-track"></div><div class="g-fill fill-upcoming" style="width:100%;opacity:0.5;border-radius:13px"></div>
            <span class="g-label inside" style="opacity:0.75">Arrows</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ──── TOOLTIPS ──── -->
  <div class="feature-row">
    <div class="feature-text">
      <span class="feature-badge free">Free</span>
      <h3>Tooltips</h3>
      <p>Cursor-following cards that show task name, date range, progress percentage, and assignee on hover. Boundary-aware — they never clip off the edge of the chart.</p>
      <div class="feature-detail">
        Dark card on light theme, light card on dark theme. Status dot, human-readable dates, and progress bar. Follows cursor with a slight offset.
      </div>
    </div>
    <div class="feature-visual">
      <div class="demo-chart" id="tooltipDemo" style="min-height:180px;cursor:default" onmouseenter="showTooltip()" onmouseleave="hideTooltip()">
        <div class="g-row"><div class="g-bar bar-done" style="left:16px;width:180px;"><div class="g-track"></div><div class="g-fill fill-done full" style="width:100%"></div><span class="g-label inside">Research</span></div></div>
        <div class="g-row">
          <div class="g-bar" id="tooltipBar" style="left:60px;width:240px;">
            <div class="g-track"></div><div class="g-fill fill-active" style="width:168px"></div>
            <div class="g-marker" style="left:168px"><div class="g-marker-inner" style="background:#574f45"></div></div>
            <span class="g-label inside">Core Architecture &middot; 70%</span>
          </div>
        </div>
        <div class="g-row"><div class="g-bar bar-upcoming" style="left:200px;width:160px;"><div class="g-track"></div><div class="g-fill fill-upcoming" style="width:100%;opacity:0.5;border-radius:13px"></div><span class="g-label inside" style="opacity:0.75">Bundle</span></div></div>
        <div class="g-row" style="height:24px"></div>
        <!-- Static tooltip (visible by default, positioned over bar) -->
        <div class="demo-tooltip show" style="top:58px;right:20px;" id="demoTooltipCard">
          <div class="demo-tooltip-name">Core Architecture</div>
          <div class="demo-tooltip-row"><span class="demo-tooltip-label">Dates</span><span>Mar 12 — Apr 8</span></div>
          <div class="demo-tooltip-row"><span class="demo-tooltip-label">Progress</span><span>70%</span></div>
          <div class="demo-tooltip-row"><span class="demo-tooltip-label">Status</span><span>Active</span></div>
          <div class="demo-tooltip-bar"><div class="demo-tooltip-bar-fill" style="width:70%"></div></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ──── DEPENDENCY ARROWS ──── -->
  <div class="feature-row reverse">
    <div class="feature-text">
      <span class="feature-badge free">Free</span>
      <h3>Dependency Arrows</h3>
      <p>SVG paths connecting dependent tasks. Start-to-start routing with right-angle joins. Hidden by default — they appear when you hover a connected bar, then fade out.</p>
      <div class="feature-detail">
        Status-based styling: solid 1.5px for active, dashed for future, lighter for completed. Right-angle routing with bezier corners. Hover any bar to see its connections.
      </div>
    </div>
    <div class="feature-visual">
      <div class="demo-chart demo-arrows" style="min-height:224px">
        <!-- Arrow SVG -->
        <svg class="demo-arrows-svg" viewBox="0 0 400 224" preserveAspectRatio="none">
          <!-- Arrow 1: bar1 → bar2 (active, solid) -->
          <path class="dep-path" d="M 42,31 L 22,31 L 22,75 L 82,75" stroke-linejoin="round"/>
          <!-- Arrow 2: bar2 → bar3 (active, solid) -->
          <path class="dep-path" d="M 82,75 L 62,75 L 62,119 L 142,119" stroke-linejoin="round"/>
          <!-- Arrow 3: bar3 → bar4 (future, dashed) -->
          <path class="dep-path future" d="M 142,119 L 122,119 L 122,163 L 222,163" stroke-linejoin="round"/>
        </svg>
        <div class="g-row">
          <div class="g-bar bar-done" style="left:42px;width:160px;"><div class="g-track"></div><div class="g-fill fill-done full" style="width:100%"></div><span class="g-label inside">Research</span></div>
        </div>
        <div class="g-row">
          <div class="g-bar" style="left:82px;width:200px;"><div class="g-track"></div><div class="g-fill fill-active" style="width:140px"></div><div class="g-marker" style="left:140px"><div class="g-marker-inner" style="background:#574f45"></div></div><span class="g-label inside">Architecture &middot; 70%</span></div>
        </div>
        <div class="g-row">
          <div class="g-bar" style="left:142px;width:160px;"><div class="g-track"></div><div class="g-fill fill-active" style="width:48px"></div><div class="g-marker" style="left:48px"><div class="g-marker-inner" style="background:#574f45"></div></div><span class="g-label inside">Extension API &middot; 30%</span></div>
        </div>
        <div class="g-row">
          <div class="g-bar bar-upcoming" style="left:222px;width:140px;"><div class="g-track"></div><div class="g-fill fill-upcoming" style="width:100%;opacity:0.5;border-radius:13px"></div><span class="g-label inside" style="opacity:0.75">Arrows</span></div>
        </div>
        <p style="position:absolute;bottom:8px;left:24px;font-family:var(--font-mono);font-size:10px;color:var(--emboss-ash);letter-spacing:0.04em">HOVER TO REVEAL ARROWS</p>
      </div>
    </div>
  </div>

  <!-- ──── THEMES ──── -->
  <div class="feature-row">
    <div class="feature-text">
      <span class="feature-badge free">Core</span>
      <h3>Light &amp; Dark</h3>
      <p>Two polished themes ship with core. Every value flows through ~20 CSS custom properties — surfaces, ink hierarchy, bar fills, track styles. Swap with one class change. Build your own theme in 20 lines of CSS.</p>
      <div class="feature-detail">
        Light theme: warm neutrals, subtle shadows, clean grid. Dark theme: full inversion — backgrounds, text, tracks, markers, tooltips all adapt. Both respond to density and view changes.
      </div>
    </div>
    <div class="feature-visual" style="border:none;box-shadow:none;background:transparent">
      <div class="demo-theme-wrap">
        <div class="demo-theme-tabs">
          <button class="demo-theme-tab active" onclick="setDemoTheme('light',this)">&#9728; Light</button>
          <button class="demo-theme-tab" onclick="setDemoTheme('dark',this)">&#9790; Dark</button>
        </div>
        <div class="demo-theme-chart" id="themeDemo">
          <div class="g-row"><div class="g-bar bar-done" style="left:12px;width:160px;"><div class="g-track"></div><div class="g-fill fill-done full" style="width:100%" id="td1"></div><span class="g-label inside">Design System</span></div></div>
          <div class="g-row"><div class="g-bar" style="left:60px;width:220px;"><div class="g-track"></div><div class="g-fill fill-active" style="width:154px" id="td2"></div><div class="g-marker" style="left:154px"><div class="g-marker-inner" style="background:#574f45" id="td2m"></div></div><span class="g-label inside">Architecture &middot; 70%</span></div></div>
          <div class="g-row"><div class="g-bar bar-upcoming" style="left:180px;width:140px;"><div class="g-track"></div><div class="g-fill fill-upcoming" style="width:100%;opacity:0.5;border-radius:13px" id="td3"></div><span class="g-label inside" style="opacity:0.75">Bundle</span></div></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ──── VIVID ──── -->
  <div class="feature-row reverse">
    <div class="feature-text">
      <span class="feature-badge paid">Organize</span>
      <h3>Vivid Mode</h3>
      <p>Color-coded bars that auto-assign from an 8-color palette. Each phase gets its own accent — blue, purple, pink, amber, green, red, cyan, orange — and every child task inherits the phase color.</p>
      <div class="feature-detail">
        Phase pills, status dots, milestone borders, and bar fills all respond to the phase color. Subtasks render at 70% opacity of the parent. Override any color with the inline color picker.
      </div>
    </div>
    <div class="feature-visual" style="border:none;box-shadow:none;background:transparent">
      <div class="demo-theme-wrap">
        <div class="demo-theme-tabs">
          <button class="demo-theme-tab" onclick="setDemoTheme('light',this)">Grayscale</button>
          <button class="demo-theme-tab vivid-active" onclick="setDemoTheme('vivid',this)">&#10022; Vivid</button>
        </div>
        <div class="demo-theme-chart" id="vividDemo">
          <div class="g-row"><div class="g-bar" style="left:12px;width:170px;"><div class="g-track"></div><div class="g-fill fill-vivid-done full" style="width:100%" id="vd1"></div><span class="g-label inside">Design System</span></div></div>
          <div class="g-row"><div class="g-bar" style="left:60px;width:200px;"><div class="g-track"></div><div class="g-fill fill-vivid-active" style="width:140px" id="vd2"></div><div class="g-marker" style="left:140px"><div class="g-marker-inner" style="background:#22d3ee" id="vd2m"></div></div><span class="g-label inside">Architecture &middot; 70%</span></div></div>
          <div class="g-row"><div class="g-bar" style="left:130px;width:160px;"><div class="g-track"></div><div class="g-fill" style="width:48px;background:linear-gradient(90deg,#a855f7,#c084fc)" id="vd3"></div><div class="g-marker" style="left:48px"><div class="g-marker-inner" style="background:#a855f7" id="vd3m"></div></div><span class="g-label inside">Extensions &middot; 30%</span></div></div>
          <div class="g-row"><div class="g-bar" style="left:200px;width:120px;"><div class="g-track"></div><div class="g-fill" style="width:100%;opacity:0.5;border-radius:13px;background:linear-gradient(90deg,#f59e0b,#fbbf24)" id="vd4"></div><span class="g-label inside" style="opacity:0.75">Testing</span></div></div>
          <!-- Vivid milestone diamonds -->
          <div style="display:flex;align-items:center;gap:20px;margin-top:14px;padding:0 4px">
            <div class="g-diamond" style="border-color:#3b82f6;position:relative;top:0">
              <div class="g-diamond-fill" style="height:100%;background:#3b82f6"></div>
              <div class="g-diamond-glass"></div>
            </div>
            <div class="g-diamond" style="border-color:#a855f7;position:relative;top:0">
              <div class="g-diamond-fill" style="height:60%;background:#a855f7"></div>
              <div class="g-diamond-glass"></div>
            </div>
            <div class="g-diamond" style="border-color:#f59e0b;position:relative;top:0">
              <div class="g-diamond-fill" style="height:30%;background:#f59e0b"></div>
              <div class="g-diamond-glass"></div>
            </div>
            <span style="font-size:11px;color:var(--emboss-ash);margin-left:4px">Phase-colored milestones</span>
          </div>
          <!-- Color palette -->
          <div style="display:flex;gap:6px;margin-top:14px;padding:0 4px">
            <span class="demo-color-dot" style="background:#3b82f6"></span>
            <span class="demo-color-dot" style="background:#a855f7"></span>
            <span class="demo-color-dot" style="background:#ec4899"></span>
            <span class="demo-color-dot" style="background:#f59e0b"></span>
            <span class="demo-color-dot" style="background:#22c55e"></span>
            <span class="demo-color-dot" style="background:#ef4444"></span>
            <span class="demo-color-dot" style="background:#22d3ee"></span>
            <span class="demo-color-dot" style="background:#f97316"></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ──── VIEWS ──── -->
  <div class="feature-row reverse">
    <div class="feature-text">
      <span class="feature-badge free">Core</span>
      <h3>Four zoom levels</h3>
      <p>Day, week, month, and quarter views — each with its own header format, grid spacing, and label thresholds. Swap with one method call.</p>
      <div class="feature-detail">
        Day view shows individual dates with weekend dimming. Week shows Monday boundaries. Month and quarter compress for roadmap-level planning. Each view &times; density combo maps to exact pixel values.
      </div>
    </div>
    <div class="feature-visual" style="border:none;box-shadow:none;background:transparent">
      <div class="demo-views-wrap">
        <div class="demo-views-tabs">
          <button class="demo-views-tab" onclick="setDemoView('day',this)">Day</button>
          <button class="demo-views-tab active" onclick="setDemoView('week',this)">Week</button>
          <button class="demo-views-tab" onclick="setDemoView('month',this)">Month</button>
          <button class="demo-views-tab" onclick="setDemoView('quarter',this)">Quarter</button>
        </div>
        <div class="demo-header" id="viewHeader">
          <span style="width:46px">Mar</span><span style="width:46px">10</span><span style="width:46px">17</span><span style="width:46px">24</span><span style="width:46px">31</span><span style="width:46px">Apr 7</span><span style="width:46px">14</span><span style="width:46px">21</span>
        </div>
        <div class="demo-chart" id="viewDemo" style="min-height:140px;padding:12px 20px">
          <div class="g-row" id="vr1"><div class="g-bar bar-done" style="left:10px;width:140px;"><div class="g-track"></div><div class="g-fill fill-done full" style="width:100%"></div><span class="g-label inside">Research</span></div></div>
          <div class="g-row" id="vr2"><div class="g-bar" style="left:50px;width:200px;"><div class="g-track"></div><div class="g-fill fill-active" style="width:140px"></div><div class="g-marker" style="left:140px"><div class="g-marker-inner" style="background:#574f45"></div></div><span class="g-label inside">Architecture &middot; 70%</span></div></div>
          <div class="g-row" id="vr3"><div class="g-bar bar-upcoming" style="left:160px;width:120px;"><div class="g-track"></div><div class="g-fill fill-upcoming" style="width:100%;opacity:0.5;border-radius:13px"></div><span class="g-label inside" style="opacity:0.75">Bundle</span></div></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ──── DENSITY MODES ──── -->
  <div class="feature-row">
    <div class="feature-text">
      <span class="feature-badge free">Core</span>
      <h3>Density modes</h3>
      <p>Three presentation contexts. Working mode for daily planning with full interactivity. Presentation mode for client demos with larger bars and hidden controls. Dense mode for big-picture overviews with compact rows and zebra striping.</p>
      <div class="feature-detail">
        Working: 44px rows, 26px bars, drag handles visible. Presentation: 60px rows, 34px bars, handles and add/delete buttons hidden, today marker enlarged. Dense: 30px rows, 18px bars, zebra striping, minibar progress indicators, floating name tags on hover.
      </div>
    </div>
    <div class="feature-visual" style="border:none;box-shadow:none;background:transparent">
      <div class="demo-views-wrap">
        <div class="demo-views-tabs">
          <button class="demo-views-tab active" onclick="setDensityMode('working',this)">Working</button>
          <button class="demo-views-tab" onclick="setDensityMode('presentation',this)">Presentation</button>
          <button class="demo-views-tab" onclick="setDensityMode('dense',this)">Dense</button>
        </div>
        <div class="demo-chart" id="densityDemo" style="min-height:180px;padding:16px 20px;transition:all 0.3s ease">
          <div class="g-row density-row" id="dr1" style="height:44px">
            <div class="g-bar bar-done" id="db1" style="left:12px;width:140px;height:26px;top:9px;border-radius:13px">
              <div class="g-track" style="border-radius:13px"></div>
              <div class="g-fill fill-done full" style="width:100%;border-radius:13px"></div>
              <div class="g-handle g-handle-l"></div><div class="g-handle g-handle-r"></div>
              <span class="g-label inside" id="dl1" style="font-size:11.5px">Research</span>
            </div>
          </div>
          <div class="g-row density-row" id="dr2" style="height:44px">
            <div class="g-bar" id="db2" style="left:60px;width:220px;height:26px;top:9px;border-radius:13px">
              <div class="g-track" style="border-radius:13px"></div>
              <div class="g-fill fill-active" style="width:154px;border-radius:13px 0 0 13px"></div>
              <div class="g-marker" id="dm2" style="left:154px"><div class="g-marker-inner" style="background:#574f45"></div></div>
              <div class="g-handle g-handle-l"></div><div class="g-handle g-handle-r"></div>
              <span class="g-label inside" id="dl2" style="font-size:11.5px">Architecture &middot; 70%</span>
            </div>
          </div>
          <div class="g-row density-row" id="dr3" style="height:44px">
            <div class="g-bar" id="db3" style="left:120px;width:160px;height:26px;top:9px;border-radius:13px">
              <div class="g-track" style="border-radius:13px"></div>
              <div class="g-fill fill-active" style="width:48px;border-radius:13px 0 0 13px"></div>
              <div class="g-marker" id="dm3" style="left:48px"><div class="g-marker-inner" style="background:#574f45"></div></div>
              <div class="g-handle g-handle-l"></div><div class="g-handle g-handle-r"></div>
              <span class="g-label inside" id="dl3" style="font-size:11.5px">Extensions &middot; 30%</span>
            </div>
          </div>
          <div class="g-row density-row" id="dr4" style="height:44px">
