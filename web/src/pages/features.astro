  /* ═══════════════════════════════════════════
     DEMO: TODAY MARKER
     ═══════════════════════════════════════════ */
  :global(.today-line) { position: absolute; top: 0; bottom: 0; width: 1.5px; background: var(--emboss-signal); opacity: 0.5; z-index: 10; }
