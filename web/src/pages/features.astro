    padding: 3px 10px; border-radius: 100px;
    background: var(--emboss-surface-inset); color: var(--emboss-ash); border: 1px solid var(--emboss-border);
  }
  :global(.future-card h3) { font-size: 17px; font-weight: 700; color: var(--emboss-coal); margin-bottom: 8px; }
  :global([data-theme="dark"] .future-card h3) { color: var(--emboss-white); }
  :global(.future-card p) { font-size: 14px; line-height: 1.65; color: var(--emboss-slate); }
  :global([data-theme="dark"] .future-card p) { color: var(--emboss-ash); }

  /* MISSION / CTA */
  .mission { padding: 120px 40px; text-align: center; }
  :global(.mission-statement) {
    font-family: var(--font-display); font-size: clamp(24px, 3.5vw, 36px);
    font-weight: 400; line-height: 1.35; color: var(--emboss-coal); max-width: 700px; margin: 0 auto;
  }
  :global([data-theme="dark"] .mission-statement) { color: var(--emboss-fog); }

  /* ═══════════════════════════════════════════
     INLINE EDITING CURSOR BLINK
     ═══════════════════════════════════════════ */
  :global(.blink-cursor) {
    border-right: 2px solid var(--emboss-press);
    animation: blink 1s step-end infinite;
  }
  @keyframes blink { 50% { border-color: transparent; } }

  /* ═══════════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════════ */
  @media (max-width: 768px) {
    .page-hero { padding: 100px 24px 60px; }
