  }
  :global(.demo-views-tab.active) { background: var(--emboss-surface); color: var(--emboss-coal); box-shadow: var(--emboss-lift-sm); }
  :global([data-theme="dark"] .demo-views-tab.active) { color: var(--emboss-white); }

  /* HEADER ROW */
  :global(.demo-header) {
    display: flex; padding: 0 20px; height: 28px; align-items: center;
    border-bottom: 1px solid var(--emboss-border);
    font-family: var(--font-mono); font-size: 10px; color: var(--emboss-ash);
    letter-spacing: 0.04em; gap: 0; overflow: hidden;
  }
  :global(.demo-header span) { text-align: center; flex-shrink: 0; }

  /* ═══════════════════════════════════════════
     COMPARISON TABLE
     ═══════════════════════════════════════════ */
  :global(.compare-table-wrap) { overflow-x: auto; margin-top: 48px; }
  :global(.compare-table) { width: 100%; border-collapse: collapse; font-size: 14px; min-width: 700px; }
  :global(.compare-table thead th) {
    padding: 16px 20px; text-align: center;
