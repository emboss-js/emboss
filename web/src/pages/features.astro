</style>

<script is:inline>
// Tooltip demo
function showTooltip() { document.getElementById('demoTooltipCard').classList.add('show'); }
function hideTooltip() { /* keep it visible as a static demo */ }

// Theme demo
function setDemoTheme(mode, btn) {
  btn.closest('.demo-theme-tabs').querySelectorAll('.demo-theme-tab').forEach(function(t) { t.classList.remove('active','vivid-active'); });
  btn.classList.add(mode === 'vivid' ? 'vivid-active' : 'active');
  var chart = document.getElementById('themeDemo');
  chart.classList.remove('dark-demo');
  var f1 = document.getElementById('td1');
  var f2 = document.getElementById('td2');
  var f3 = document.getElementById('td3');
  var m = document.getElementById('td2m');
  if (mode === 'dark') {
    chart.classList.add('dark-demo');
    f1.className = 'g-fill fill-done full'; f2.className = 'g-fill fill-active'; f3.className = 'g-fill fill-upcoming';
    m.style.background = '#574f45';
  } else if (mode === 'vivid') {
    f1.className = 'g-fill fill-vivid-done full'; f2.className = 'g-fill fill-vivid-active'; f3.className = 'g-fill fill-vivid-active';
    m.style.background = '#22d3ee';
  } else {
    f1.className = 'g-fill fill-done full'; f2.className = 'g-fill fill-active'; f3.className = 'g-fill fill-upcoming';
    m.style.background = '#574f45';
  }
}

// Glass bars demo — grayscale/vivid toggle
function setBarMode(mode, btn) {
  btn.closest('.demo-theme-tabs').querySelectorAll('.demo-theme-tab').forEach(function(t) { t.classList.remove('active','vivid-active'); });
  btn.classList.add(mode === 'vivid' ? 'vivid-active' : 'active');
  var demo = document.getElementById('glassDemo');
  var vivid = mode === 'vivid';
  demo.querySelectorAll('.gb-active').forEach(function(el) {
    el.className = el.className.replace(/fill-(vivid-)?active/, vivid ? 'fill-vivid-active' : 'fill-active');
  });
  demo.querySelectorAll('.gb-done').forEach(function(el) {
    el.className = el.className.replace(/fill-(vivid-)?done/, vivid ? 'fill-vivid-done' : 'fill-done');
  });
  demo.querySelectorAll('.gb-upcoming').forEach(function(el) {
    el.className = el.className.replace(/fill-(vivid-)?upcoming/, vivid ? 'fill-vivid-upcoming' : 'fill-upcoming');
  });
  demo.querySelectorAll('.gb-marker').forEach(function(el) {
    el.style.background = vivid ? '#22d3ee' : '#574f45';
  });
}

// View demo
function setDemoView(view, btn) {
  document.querySelectorAll('.demo-views-tab').forEach(function(t) { t.classList.remove('active'); });
  btn.classList.add('active');
  var h = document.getElementById('viewHeader');
  var scales = {
    day: { labels: '<span style="width:32px">M10</span><span style="width:32px">T11</span><span style="width:32px">W12</span><span style="width:32px">T13</span><span style="width:32px">F14</span><span style="width:32px">M17</span><span style="width:32px">T18</span><span style="width:32px">W19</span><span style="width:32px">T20</span><span style="width:32px">F21</span><span style="width:32px">M24</span><span style="width:32px">T25</span>', bars: [{l:5,w:160},{l:35,w:230},{l:180,w:140}] },
    week: { labels: '<span style="width:46px">Mar</span><span style="width:46px">10</span><span style="width:46px">17</span><span style="width:46px">24</span><span style="width:46px">31</span><span style="width:46px">Apr 7</span><span style="width:46px">14</span><span style="width:46px">21</span>', bars: [{l:10,w:140},{l:50,w:200},{l:160,w:120}] },
    month: { labels: '<span style="width:60px">Feb</span><span style="width:60px">Mar</span><span style="width:60px">Apr</span><span style="width:60px">May</span><span style="width:60px">Jun</span><span style="width:60px">Jul</span>', bars: [{l:70,w:80},{l:100,w:110},{l:160,w:80}] },
    quarter: { labels: '<span style="width:90px">Q1 2026</span><span style="width:90px">Q2 2026</span><span style="width:90px">Q3 2026</span><span style="width:90px">Q4 2026</span>', bars: [{l:50,w:50},{l:65,w:70},{l:100,w:50}] }
  };
  var s = scales[view];
  h.innerHTML = s.labels;
  ['vr1','vr2','vr3'].forEach(function(id, i) {
    var bar = document.getElementById(id).querySelector('.g-bar');
    bar.style.left = s.bars[i].l + 'px';
    bar.style.width = s.bars[i].w + 'px';
  });
}

// Scroll animations
var obs = new IntersectionObserver(function(entries) {
  entries.forEach(function(e) { if(e.isIntersecting){e.target.style.opacity='1';e.target.style.transform='translateY(0)';} });
}, {threshold:0.08});
document.querySelectorAll('.section,.mission,.page-hero').forEach(function(el) {
  el.style.opacity='0'; el.style.transform='translateY(24px)';
  el.style.transition='opacity 0.7s ease, transform 0.7s ease';
  obs.observe(el);
});
</script>
