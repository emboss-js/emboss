    border-bottom: 2px solid var(--emboss-border);
  }
  :global([data-theme="dark"] .compare-table thead th) { color: var(--emboss-white); }
  :global(.compare-table thead th:first-child) { text-align: left; }
  :global(.compare-table thead th.featured) {
    background: var(--emboss-surface-raised); border-radius: 12px 12px 0 0; position: relative;
  }
  :global(.compare-table thead th.featured::before) {
    content: 'Recommended'; position: absolute; top: -10px; left: 50%; transform: translateX(-50%);
    padding: 2px 12px; border-radius: 100px;
    background: var(--emboss-gradient); color: white;
    font-family: var(--font-mono); font-size: 9px; font-weight: 500;
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  :global(.compare-table tbody td) {
    padding: 12px 20px; text-align: center;
    border-bottom: 1px solid var(--emboss-border); color: var(--emboss-slate);
  }
  :global([data-theme="dark"] .compare-table tbody td) { color: var(--emboss-ash); }
  :global(.compare-table tbody td:first-child) { text-align: left; font-weight: 500; color: var(--emboss-coal); }
  :global([data-theme="dark"] .compare-table tbody td:first-child) { color: var(--emboss-fog); }
  :global(.compare-table tbody td.featured) { background: var(--emboss-surface-raised); }
  :global(.compare-table .check) {
    display: inline-block; font-weight: 700;
    background: var(--emboss-gradient-text);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  :global(.compare-table .dash) { color: var(--emboss-cloud); }
  :global([data-theme="dark"] .compare-table .dash) { color: var(--emboss-graphite); }
  :global(.compare-table .soon) {
    font-family: var(--font-mono); font-size: 10px; font-weight: 500;
    letter-spacing: 0.04em; text-transform: uppercase;
    color: var(--emboss-ash); opacity: 0.7;
  }
  :global(.compare-table .group-row td) {
    font-family: var(--font-mono); font-size: 10px; font-weight: 500;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--emboss-ash); padding: 20px 20px 8px; border-bottom: none;
  }
  :global(.compare-table tfoot td) { padding: 20px; border-top: 2px solid var(--emboss-border); text-align: center; }

  /* ═══════════════════════════════════════════
     FUTURE BUNDLES
     ═══════════════════════════════════════════ */
  :global(.future-grid) { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
  :global(.future-card) {
    padding: 32px; border-radius: 20px;
    background: var(--emboss-surface-raised); border: 1px solid var(--emboss-border);
