    height: 26px; border-radius: 13px; position: absolute;
    top: 9px; overflow: hidden; cursor: pointer;
    transition: transform 0.2s, opacity 0.2s;
  }
  :global(.g-bar:hover) { transform: scaleY(1.08); }
