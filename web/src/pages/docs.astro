<style>
  /* ═══ DOCS LAYOUT ═══ */
  .docs-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    max-width: 1200px;
    margin: 0 auto;
    padding-top: 80px;
    min-height: 100vh;
  }

  /* SIDEBAR */
  .docs-sidebar {
    padding: 32px 24px 60px 40px;
    border-right: 1px solid var(--emboss-border);
    position: sticky;
    top: 80px;
    height: calc(100vh - 80px);
    overflow-y: auto;
  }
  .docs-sidebar-section {
    margin-bottom: 28px;
  }
  .docs-sidebar-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--emboss-ash);
    margin-bottom: 10px;
  }
  .docs-sidebar ul {
    list-style: none;
  }
  .docs-sidebar li {
    margin-bottom: 2px;
  }
  .docs-sidebar a {
    display: block;
    padding: 6px 12px;
    border-radius: 8px;
    font-size: 13.5px;
    color: var(--emboss-slate);
    transition: all 0.15s;
    text-decoration: none;
  }
  .docs-sidebar a:hover {
    background: var(--emboss-surface-raised);
    color: var(--emboss-coal);
  }
  :global([data-theme="dark"]) .docs-sidebar a:hover {
    color: var(--emboss-white);
  }
  .docs-sidebar a.active {
    background: var(--emboss-surface-raised);
    color: var(--emboss-coal);
    font-weight: 600;
  }
  :global([data-theme="dark"]) .docs-sidebar a.active {
    color: var(--emboss-white);
  }

  /* CONTENT — uses :global because content is injected via set:html */
  :global(.docs-content) {
    padding: 40px 60px 100px 48px;
    max-width: 760px;
  }
  :global(.docs-content h1) {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--emboss-coal);
    margin-bottom: 8px;
  }
  :global([data-theme="dark"] .docs-content h1) {
    color: var(--emboss-white);
  }
  :global(.docs-content .subtitle) {
    font-size: 17px;
    color: var(--emboss-slate);
    line-height: 1.7;
    margin-bottom: 40px;
  }
  :global([data-theme="dark"] .docs-content .subtitle) {
    color: var(--emboss-ash);
  }
  :global(.docs-content h2) {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 700;
    color: var(--emboss-coal);
    margin-top: 48px;
    margin-bottom: 12px;
    padding-top: 24px;
    border-top: 1px solid var(--emboss-border);
  }
  :global([data-theme="dark"] .docs-content h2) {
    color: var(--emboss-white);
  }
  :global(.docs-content h2:first-of-type) {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
  }
  :global(.docs-content h3) {
    font-size: 16px;
    font-weight: 600;
    color: var(--emboss-coal);
    margin-top: 32px;
    margin-bottom: 8px;
  }
  :global([data-theme="dark"] .docs-content h3) {
    color: var(--emboss-fog);
  }
  :global(.docs-content p) {
    font-size: 15px;
    line-height: 1.7;
    color: var(--emboss-slate);
    margin-bottom: 16px;
  }
  :global([data-theme="dark"] .docs-content p) {
    color: var(--emboss-ash);
  }

  /* Lists */
  :global(.docs-list) {
    font-size: 15px;
    line-height: 1.7;
    color: var(--emboss-slate);
    margin-bottom: 16px;
    padding-left: 24px;
  }
  :global(.docs-list li) {
    margin-bottom: 6px;
  }
  :global([data-theme="dark"] .docs-list) {
    color: var(--emboss-ash);
  }

  /* Code blocks */
  :global(.docs-code) {
    background: var(--emboss-graphite);
    color: #e5e7eb;
    padding: 20px 24px;
    border-radius: 12px;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.7;
    overflow-x: auto;
    margin: 16px 0 24px;
    border: 1px solid rgba(250,248,244,0.06);
  }
  :global(.docs-code .kw) { color: #22d3ee; }
  :global(.docs-code .str) { color: #38bdf8; }
  :global(.docs-code .fn) { color: #60a5fa; }
  :global(.docs-code .cm) { color: #6b7280; font-style: italic; }
  :global(.docs-code .num) { color: #fbbf24; }

  /* Inline code */
  :global(.docs-content code) {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--emboss-surface-inset);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--emboss-coal);
  }
  :global([data-theme="dark"] .docs-content code) {
    background: var(--emboss-surface-raised);
    color: var(--emboss-fog);
  }

  /* Placeholder badge */
  :global(.docs-content .placeholder) {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    border-radius: 100px;
    background: var(--emboss-surface-inset);
    border: 1px solid var(--emboss-border);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--emboss-ash);
    margin-bottom: 16px;
  }

  /* Prop table */
  :global(.prop-table) {
    width: 100%;
    border-collapse: collapse;
    margin: 16px 0 24px;
    font-size: 13.5px;
  }
  :global(.prop-table th) {
    text-align: left;
    padding: 8px 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--emboss-ash);
    border-bottom: 2px solid var(--emboss-border);
  }
  :global(.prop-table td) {
    padding: 10px 12px;
    border-bottom: 1px solid var(--emboss-border);
    color: var(--emboss-slate);
    line-height: 1.5;
  }
  :global([data-theme="dark"] .prop-table td) {
    color: var(--emboss-ash);
  }
  :global(.prop-table td:first-child) {
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--emboss-coal);
    font-weight: 500;
  }
  :global([data-theme="dark"] .prop-table td:first-child) {
    color: var(--emboss-fog);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .docs-layout {
      grid-template-columns: 1fr;
    }
    .docs-sidebar {
      display: none;
    }
    :global(.docs-content) {
      padding: 32px 24px 80px;
    }
  }
</style>

<script>
  // Sidebar active state on scroll
  const sections = document.querySelectorAll('.docs-content h2[id]');
  const sidebarLinks = document.querySelectorAll('.docs-sidebar a');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        sidebarLinks.forEach(l => l.classList.remove('active'));
        const match = document.querySelector('.docs-sidebar a[href="#' + e.target.id + '"]');
        if (match) match.classList.add('active');
      }
    });
  }, { rootMargin: '-80px 0px -70% 0px' });

  sections.forEach(s => observer.observe(s));
</script>
